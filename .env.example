# Server Configuration
PORT=3000
NODE_ENV=production

# Firebase Client Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin Service Account
# Download service account key from Firebase Console > Project Settings > Service Accounts
# Convert the JSON content to a single line and set as environment variable
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","private_key_id":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Transport API Configuration
# Flight API (Amadeus or Aviation Stack)
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
# OR
AVIATION_STACK_API_KEY=your_aviation_stack_api_key

# Train API (RapidAPI or similar)
RAPIDAPI_KEY=your_rapidapi_key
INDIAN_RAILWAYS_API_HOST=indian-railways-api.p.rapidapi.com

# Bus API (RapidAPI or similar)
REDBUS_API_KEY=your_redbus_api_key
# OR
ABHIBUS_API_KEY=your_abhibus_api_key

# API Configuration
API_TIMEOUT_MS=10000
API_MAX_RETRIES=3
API_CACHE_TTL_MS=300000

# Server Configuration
PORT=3000
NODE_ENV=production
