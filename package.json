{
  "name": "bookmyway",
  "version": "1.0.0",
  "description": "Travel comparison platform for booking flights, buses, and trains",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "node dist/index.js",
