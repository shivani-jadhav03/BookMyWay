    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "helmet": "^7.1.0",
    "querystring": "^0.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
